# Supabase — find these in your project's API settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Claude API key is used server-side only (Vercel function), never expose it here.

# Web Push — public VAPID key (safe to expose). Generate a keypair with:
#   npx web-push generate-vapid-keys
# Put the PUBLIC key here, and the PRIVATE key in server env only (see below).
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# --- Server-side only (set in Vercel project env, NOT with a VITE_ prefix) ---
# VAPID_PUBLIC_KEY          same public key as above
# VAPID_PRIVATE_KEY         the private VAPID key (keep secret)
# VAPID_SUBJECT             mailto:you@example.com
# SUPABASE_URL              your Supabase project URL
# SUPABASE_SERVICE_ROLE_KEY service-role key (bypasses RLS to read food logs)
# CRON_SECRET               any random string; Vercel Cron sends it automatically
